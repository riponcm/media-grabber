{
  "manifest_version": 3,
  "name": "Media Grabber - Video & Audio Downloader",
  "version": "1.0.0",
  "author": "Matily",
  "description": "Video and audio downloader for the web. Detect and save media from any page, with HLS/DASH (m3u8) support via FFmpeg.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["webRequest", "downloads", "storage", "tabs", "scripting", "tabCapture", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Media Grabber",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "src/recorder.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
